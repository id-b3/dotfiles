# ==============================================================================
# 1. STARSHIP (Primary Prompt)
# ==============================================================================
# If Starship is installed, initialize it and exit this file immediately.
# This prevents wasting CPU cycles building a fallback prompt we won't use.
if command -v "$HOME/.local/bin/starship" >/dev/null 2>&1; then
    eval -- "$("$HOME/.local/bin/starship" init bash)"
    return
elif command -v starship >/dev/null 2>&1; then
    eval -- "$(starship init bash)"
    return
fi

# ==============================================================================
# 2. FALLBACK PROMPT (If Starship is not installed)
# ==============================================================================

# -- Color Definitions --
FMT_BOLD="\[\e[1m\]"
FMT_UNBOLD="\[\e[22m\]"
FMT_RESET="\[\e[0m\]"
FG_BLACK="\[\e[30m\]"
FG_BLUE="\[\e[34m\]"
FG_CYAN="\[\e[36m\]"
FG_YELLOW="\[\e[33m\]"
FG_GREY="\[\e[37m\]"
FG_MAGENTA="\[\e[35m\]"
FG_WHITE="\[\e[97m\]"
BG_BLUE="\[\e[44m\]"
BG_CYAN="\[\e[46m\]"
BG_YELLOW="\[\e[43m\]"
BG_MAGENTA="\[\e[45m\]"

# -- Helper Functions --
function parse_venv_env() {
    if [ -n "$VIRTUAL_ENV" ]; then
        if [ -n "$VIRTUAL_ENV_PROMPT" ]; then
            echo -e "${FG_WHITE}${VIRTUAL_ENV_PROMPT} "
        else
            echo -e "${FG_WHITE}($(basename "$VIRTUAL_ENV")) "
        fi
    fi
}

function get_terminal_emoji() {
    if [ -n "$SSH_CONNECTION" ] || [ -n "$SSH_CLIENT" ]; then
        echo "⛅"
    else
        echo "💻"
    fi
}

function get_git_branch() {
    # Fast, modern way to get git branch without piping through grep/colrm
    local branch
    branch=$(git branch --show-current 2>/dev/null)
    if [ -n "$branch" ]; then
        echo -e "${FG_CYAN}${BG_YELLOW}▶ ${FG_BLACK}🔀${FMT_BOLD} ${branch} ${FMT_RESET}${FG_YELLOW}"
    fi
}

# -- Build the PS1 String --
# We build it piece by piece for readability. 

PS1="\n ${FG_BLUE}╭─" # begin arrow to prompt
PS1+="${FG_MAGENTA}◀" # begin USERNAME container
PS1+="${BG_MAGENTA}${FG_CYAN}${FMT_BOLD} \$(get_terminal_emoji) " # dynamically set emoji
PS1+="${FG_WHITE}\u" # print username
PS1+="${FMT_UNBOLD}${FMT_BOLD} ${FG_MAGENTA}${BG_BLUE}▶ " # end USERNAME container / begin DIRECTORY container
PS1+="${FG_GREY}\w " # print directory
PS1+="${FG_BLUE}▶${FMT_RESET} " # end DIRECTORY container

# Append Git branch dynamically (only shows if in a git repo)
PS1+="\$(get_git_branch)"

# Final line
PS1+="\n ${FG_BLUE}╰❯ " # end arrow to prompt
PS1+="\$(parse_venv_env)" # print venv
PS1+="${FG_CYAN}\\$ ${FMT_RESET}" # print prompt

export PS1
