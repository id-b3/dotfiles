# ==============================================================================
# 1. CORE BEHAVIOR
# ==============================================================================
# Graceful editor fallback (tries nvim, then vim, then nano)
export VISUAL="$(command -v nvim || command -v vim || command -v nano)"
export EDITOR="$VISUAL"

# Disable default virtual environment prompt so we can style it ourselves
export VIRTUAL_ENV_DISABLE_PROMPT=1

# Colored GCC warnings and errors
export GCC_COLORS='error=01;31:warning=01;35:note=01;36:caret=01;32:locus=01:quote=01'

# ==============================================================================
# 2. PATH HYGIENE (Only add directories if they actually exist)
# ==============================================================================
_prepend_path() { [ -d "$1" ] && export PATH="$1:$PATH"; }
_prepend_ld() { [ -d "$1" ] && export LD_LIBRARY_PATH="$1:${LD_LIBRARY_PATH:-}"; }

# Standard local bin directories
_prepend_path "$HOME/.local/bin"
_prepend_path "$HOME/bin"

# Generic nodejs fallback (if fnm from .bashrc isn't handling it)
_prepend_path "$HOME/lib/nodejs/bin"

# Clean up helper functions so they don't clutter your shell namespace
unset -f _prepend_path _prepend_ld
